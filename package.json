{
  "name": "web-monitor",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n server,frontend -c blue,green \"npm run dev -w server\" \"npm run dev -w frontend\"",
    "dev:server": "npm run dev -w server",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend && npm run build -w server",
    "start": "npm run start -w server",
    "postinstall": "npm run install:browsers -w server",
    "setup:bingleimuzi": "node scripts/setup-bingleimuzi-balance.mjs",
    "setup:getquicker": "node scripts/setup-getquicker-sharedaction.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
